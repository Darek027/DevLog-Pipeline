      "parameters": {
        "jsCode": "// Pobieramy zawartość 'body' z payloadu GitHuba przechwyconego przez Webhook\nconst payload = $input.all()[0].json.body;\n\n// Celujemy w obiekt z najnowszym commitem (head_commit)\nconst headCommit = payload.head_commit;\n\n// Zabezpieczenie: jeśli to zdarzenie nie zawiera commita (np. utworzenie pustego brancha)\nif (!headCommit) {\n  return [];\n}\n\n// Zwracamy czysty, sformatowany JSON z danymi gotowymi do wstrzyknięcia do bazy\nreturn {\n  commit_hash: headCommit.id,\n  message: headCommit.message\n};"
